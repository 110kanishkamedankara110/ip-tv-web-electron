{
  "name": "ip-tv-web",
  "version": "1.0.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next export",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.flowtv.app",
    "productName": "FlowTV",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "electron/VLC",
        "to": "VLC"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.26",
    "axios": "^1.16.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-serve": "^3.0.1",
    "express": "^5.2.1",
    "hls.js": "^1.6.16",
    "m3u-parser": "^1.0.3",
    "m3u-parser-generator": "^5.0.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-window": "^2.2.7",
    "serve": "^14.2.6",
    "tree-kill": "^1.2.2",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
